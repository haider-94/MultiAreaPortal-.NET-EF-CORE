@model IEnumerable<Event>
@{
    ViewData["Title"] = "Manage Events";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Manage Events</h1>
    <a class="btn btn-primary" asp-action="Create">+ New Event</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th class="text-end">Ticket Price</th>
                <th>Event Date</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in Model)
            {
                <tr>
                    <td>@ev.Name</td>
                    <td class="text-end">@ev.TicketPrice.ToString("C")</td>
                    <td>@ev.EventDate.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@ev.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@ev.Id">Details</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@ev.Id">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@ev.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No events yet. Click <strong>New Event</strong> to create one.</p>
}
